{
  "name": "usereflow",
  "version": "1.3.0",
  "description": "The complete, SSR-safe, framework-agnostic responsive toolkit for TypeScript: typed breakpoints, fluid clamp, container queries, modern preference media, and a first-class React adapter \u2014 zero runtime deps.",
  "keywords": [
    "responsive",
    "responsive-design",
    "breakpoints",
    "media-query",
    "container-queries",
    "container-query",
    "fluid-typography",
    "fluid-design",
    "clamp",
    "css-clamp",
    "react",
    "react-hooks",
    "vue",
    "svelte",
    "astro",
    "typescript",
    "ssr",
    "ssr-safe",
    "hydration",
    "nextjs",
    "remix",
    "viewport",
    "window-size",
    "device",
    "matchmedia",
    "dark-mode",
    "use-media-query",
    "use-breakpoint",
    "responsive-hooks",
    "design-tokens",
    "useSyncExternalStore",
    "prefers-reduced-motion",
    "prefers-color-scheme",
    "tailwindcss"
  ],
  "license": "MIT",
  "author": "Tamish Mhatre <tamishmhatre26@gmail.com>",
  "homepage": "https://github.com/valtors/reflow#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/valtors/reflow.git"
  },
  "bugs": {
    "url": "https://github.com/valtors/reflow/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/valtors"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "require": {
        "types": "./dist/react/index.d.cts",
        "default": "./dist/react/index.cjs"
      }
    },
    "./preact": {
      "import": {
        "types": "./dist/preact/index.d.ts",
        "default": "./dist/preact/index.js"
      },
      "require": {
        "types": "./dist/preact/index.d.cts",
        "default": "./dist/preact/index.cjs"
      }
    },
    "./styles": {
      "import": {
        "types": "./dist/styles/index.d.ts",
        "default": "./dist/styles/index.js"
      },
      "require": {
        "types": "./dist/styles/index.d.cts",
        "default": "./dist/styles/index.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.js"
      },
      "require": {
        "types": "./dist/server/index.d.cts",
        "default": "./dist/server/index.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing/index.d.ts",
        "default": "./dist/testing/index.js"
      },
      "require": {
        "types": "./dist/testing/index.d.cts",
        "default": "./dist/testing/index.cjs"
      }
    },
    "./tailwind": {
      "import": {
        "types": "./dist/tailwind/index.d.ts",
        "default": "./dist/tailwind/index.js"
      },
      "require": {
        "types": "./dist/tailwind/index.d.cts",
        "default": "./dist/tailwind/index.cjs"
      }
    },
    "./vue": {
      "import": {
        "types": "./dist/vue/index.d.ts",
        "default": "./dist/vue/index.js"
      },
      "require": {
        "types": "./dist/vue/index.d.cts",
        "default": "./dist/vue/index.cjs"
      }
    },
    "./svelte": {
      "import": {
        "types": "./dist/svelte/index.d.ts",
        "default": "./dist/svelte/index.js"
      },
      "require": {
        "types": "./dist/svelte/index.d.cts",
        "default": "./dist/svelte/index.cjs"
      }
    },
    "./solid": {
      "import": {
        "types": "./dist/solid/index.d.ts",
        "default": "./dist/solid/index.js"
      },
      "require": {
        "types": "./dist/solid/index.d.cts",
        "default": "./dist/solid/index.cjs"
      }
    },
    "./angular": {
      "import": {
        "types": "./dist/angular/index.d.ts",
        "default": "./dist/angular/index.js"
      },
      "require": {
        "types": "./dist/angular/index.d.cts",
        "default": "./dist/angular/index.cjs"
      }
    },
    "./lit": {
      "import": {
        "types": "./dist/lit/index.d.ts",
        "default": "./dist/lit/index.js"
      },
      "require": {
        "types": "./dist/lit/index.d.cts",
        "default": "./dist/lit/index.cjs"
      }
    },
    "./qwik": {
      "import": {
        "types": "./dist/qwik/index.d.ts",
        "default": "./dist/qwik/index.js"
      },
      "require": {
        "types": "./dist/qwik/index.d.cts",
        "default": "./dist/qwik/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src test",
    "lint:fix": "biome check --write src test",
    "format": "biome format --write src test",
    "size": "size-limit",
    "publint": "publint",
    "attw": "attw --pack . --profile esm-only --ignore-rules=no-resolution",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build && npm run publint && npm run attw && npm run size",
    "release": "changeset publish"
  },
  "peerDependencies": {
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0",
    "lit": ">=3.0.0",
    "preact": ">=10.0.0",
    "react": ">=17.0.0",
    "rxjs": ">=7.8.0",
    "solid-js": ">=1.8.0",
    "svelte": ">=4.0.0",
    "vue": ">=3.3.0",
    "@builder.io/qwik": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/common": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "lit": {
      "optional": true
    },
    "preact": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "@builder.io/qwik": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/common": "^19.2.15",
    "@angular/core": "^19.2.15",
    "@arethetypeswrong/cli": "^0.17.0",
    "@biomejs/biome": "^1.9.0",
    "@builder.io/qwik": "1.17.2",
    "@changesets/cli": "^2.27.0",
    "@size-limit/preset-small-lib": "^11.1.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "happy-dom": "^15.0.0",
    "lit": "^3.2.1",
    "preact": "^10.26.5",
    "publint": "^0.2.10",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "rxjs": "^7.8.2",
    "size-limit": "^11.1.0",
    "solid-js": "^1.9.9",
    "svelte": "^5.55.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "vue": "^3.5.34"
  },
  "size-limit": [
    {
      "name": "core (esm, gz)",
      "path": "dist/index.js",
      "limit": "5 KB"
    },
    {
      "name": "react adapter (esm, gz)",
      "path": "dist/react/index.js",
      "limit": "5 KB"
    },
    {
      "name": "styles (esm, gz)",
      "path": "dist/styles/index.js",
      "limit": "3 KB"
    },
    {
      "name": "server (esm, gz)",
      "path": "dist/server/index.js",
      "limit": "2 KB"
    }
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
